# ─────────────────────────────────────────────────────────────────────────────
# Dev Branch
# ─────────────────────────────────────────────────────────────────────────────
# Only exclude truly unnecessary files, keep build files for development

# Node.js dependencies (large, can be recreated)
node_modules/
npm-debug.log*
yarn-error.log

# Built folder (exclude from dev branch)
build
data
backend

# npm install generated folders
.angular/
.sass-cache/
.webpack/
coverage/
tmp/
out-tsc/
.ngcache/

# Python cache (can be recreated)
__pycache__/
*.pyc
*.pyo

# IDE files that shouldn't be shared
.vscode/settings.json
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db