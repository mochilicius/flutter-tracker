# Flutter App - Dev Branch Minimal GitIgnore
# Only exclude truly unnecessary files, include build files for development

# Node.js dependencies (large, can be recreated)
node_modules/
npm-debug.log*
yarn-error.log

# IDE files that shouldn't be shared
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# NOTE: For dev branch, we INCLUDE Angular build files:
# - /dist - Angular builds for testing
# - /tmp, /out-tsc - build outputs
# - /.angular/cache - can be recreated but useful for development
